# DocuMind backend — copy to backend/.env
# Get a key: https://aistudio.google.com/apikey

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=documind_chunks

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,https://documind-beige.vercel.app,https://documind-app-two.vercel.app

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_K=6

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
