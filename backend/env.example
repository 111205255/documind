# Copy to backend/.env (never commit .env)

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional — require X-API-Key on ingest/chat/delete when set
RAG_API_KEY=

# Optional — when set, clients must send Authorization: Bearer <supabase_jwt>
# and only the document owner may ingest/chat/delete (via service role check)
SUPABASE_URL=https://vazxfcgbaawbreziszmy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Set to "production" on Render for fail-closed auth
ENVIRONMENT=development

CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=documind_chunks

CORS_ORIGINS=http://localhost:3000,http://localhost:8081,https://documind-beige.vercel.app,https://documind-app-two.vercel.app

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_K=6
